{
    "suggest.noselect": true,
    "suggest.preferCompleteThanJumpPlaceholder": true,
    "suggest.enablePreselect": true,
    "clangd.disableSnippetCompletion": true,
    "tsserver.enableJavascript": true,
    "eslint.filetypes": ["javascript", "typescript", "typescriptreact", "javascriptreact", "typescript.tsxB"],
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
    "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
    "coc.preferences.formatOnSaveFiletypes": ["haskell"],
    "prettier.eslintIntegration": true,
    "typescript.showUnused": false,
    "solargraph.commandPath": "/Users/shimehituzi/.rbenv/shims/solargraph",
    "languageserver": {
        "haskell": {
            "command": "haskell-language-server-wrapper",
            "args": ["--lsp"],
            "rootPatterns": ["*.cabal", "stack.yaml", "cabal.project", "package.yaml", "hie.yaml"],
            "filetypes": ["haskell", "lhaskell"]
        }
    }
}
